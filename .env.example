# ===== AAA Discord Bot 환경 변수 =====
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채운다.
#   Windows:  copy .env.example .env
# .env 는 .gitignore 에 등록되어 커밋되지 않는다.

# [필수] Discord Bot Token
# Discord Developer Portal > 내 앱 > Bot > Reset Token 에서 발급
DISCORD_TOKEN=

# [선택] AAA 저장소 루트 경로. 비우면 봇 실행 디렉토리(.) 기준.
# Windows 예: C:\Users\me\aaa
AAA_ROOT=.

# [선택, 권장] 특정 서버에서만 동작하게 제한. 비우면 전역.
AAA_ALLOWED_GUILD_ID=

# [선택, 권장] 특정 채널에서만 동작하게 제한. 비우면 모든 채널.
AAA_ALLOWED_CHANNEL_ID=

# [선택] 관리자 유저 ID (2차 /정지 등에서 사용 예정)
AAA_ADMIN_USER_ID=
