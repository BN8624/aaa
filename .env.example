# ===== AAA Discord Bot 환경 변수 =====
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채운다.
#   Windows:  copy .env.example .env
# .env 는 .gitignore 에 등록되어 커밋되지 않는다.

# [필수] Discord Bot Token
# Discord Developer Portal > 내 앱 > Bot > Reset Token 에서 발급
DISCORD_TOKEN=

# [선택] AAA 저장소 루트 경로. 비우면 봇 실행 디렉토리(.) 기준.
# Windows 예: C:\Users\me\aaa
AAA_ROOT=.

# [선택, 권장] 특정 서버에서만 동작하게 제한. 비우면 전역.
AAA_ALLOWED_GUILD_ID=

# [선택, 권장] 특정 채널에서만 동작하게 제한. 비우면 모든 채널.
AAA_ALLOWED_CHANNEL_ID=

# [선택] 관리자 유저 ID (2차 /정지 등에서 사용 예정)
AAA_ADMIN_USER_ID=

# ===== 모델 인증 (§28) =====
# 경로 A — 정식 Vertex 인증(권장, 프로젝트 quota): 아래 3개를 다 채우면 자동 사용.
#   서비스계정 JSON 키 파일의 절대 경로. 예: C:\Users\USER\aaa\vertex-sa.json
GOOGLE_APPLICATION_CREDENTIALS=
#   GCP 프로젝트 ID (콘솔 상단 프로젝트 선택기에 보이는 ID)
VERTEX_PROJECT=
#   리전. 공식 퀵스타트 기본값은 global(신형 Gemini는 global에만 있을 수 있음). 특정 리전이면 us-central1 등.
VERTEX_LOCATION=global
#   ↑ 정식 인증엔 패키지 필요: pip install google-auth requests
#
# 경로 B — express API 키(폴백): 위 3개가 비어 있으면 이 키를 쓴다(분당 ~6 저캡).
VERTEX_API_KEY=
